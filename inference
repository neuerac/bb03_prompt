# 从 text 里解析情感标签【xxx】，取基础情感（字母部分，忽略档位数字）
EMO_TAG_RE = re.compile(r"【([A-Za-z]+?)(\d*)】")
# 已知支持情感（用于校验 / 兜底）
KNOWN_EMOTIONS = {
    "happy", "sad", "angry", "fearful", "surprised",
    "disgusted", "excited", "anxiety", "neutral", "calm",
}
EMO_MAP = {
    "fearful": "fear",
    "angry": "anger",
    "calm": "calmness",
    "excited": "excitement",
    "surprised": "surprise",
    "sad": "sadness",
    "disgusted": "disgust",
}

