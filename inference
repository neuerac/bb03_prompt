def _fallback_per_item(tts, batch: list[dict], args) -> tuple[list, int]:
    """批处理失败时逐条合成，失败的条目对应 None。"""
    wavs: list = []
    sr = 24000
    for b in batch:
        try:
            w, sr = tts.generate_voice_clone(
                text=b["输入文本"],
                language=args.language,
                ref_audio=b["_ref_audio"],
                ref_text=b["_ref_text"],
                x_vector_only_mode=args.x_vector_only,
                non_streaming_mode=True,
                # **COMMON_GEN_KWARGS,
            )
            wavs.append(w[0])
        except Exception as exc:  # noqa: BLE001
            print(f"    [{b['ID']}] 单条失败: {exc}", file=sys.stderr)
            wavs.append(None)
    return wavs, sr

