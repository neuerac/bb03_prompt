    python infer_control_eval_v6.py \
        --model /path/to/controllable_ckpt \
        --ref_jsonl /path/to/ref_with_emotion.jsonl \
        --input control_eval_v6.jsonl \
        --out_dir v6_infer_out \
        [--batch_size 8] [--limit 0] [--seed 0]
"""

