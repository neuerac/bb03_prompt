# 从 text 里解析情感标签【xxx】，取基础情感（字母部分，忽略档位数字）
# 从 text 里解析情绪标签【xxx】。1/2/3 是强度档位；无数字表示没有强度约束。
EMO_TAG_RE = re.compile(r"【([A-Za-z ]+?)([123]?)】")

# 测试集与 BB03 的同义情绪名统一到 BB03 使用的基础名。
EMOTION_ALIASES = {
    "happy": "happy",
    "sad": "sadness", "sadness": "sadness",
    "angry": "anger", "anger": "anger",
    "fearful": "fear", "fear": "fear",
    "surprised": "surprise", "surprise": "surprise",
    "disgusted": "disgust", "disgust": "disgust",
    "excited": "excitement", "excitement": "excitement",
    "anxiety": "anxiety",
    "neutral": "neutral",
    "calm": "calmness", "calmness": "calmness",
}
