def base_emotion_from_text(text: str) -> str | None:
    """取文本中第一个【tag】的基础情感名（小写）；无标签返回 None。"""
    m = EMO_TAG_RE.search(text or "")
    if not m:
        return None
    return m.group(1).lower()

def target_emotion_for_entry(rec: dict) -> str:
    """测试条目应匹配的参考情感（基础名）。

    - 情感/复合：输入文本开头的【tag】里带情感；
    - 副语言/韵律/音量：无情感标注 -> neutral。
    """
    emo = base_emotion_from_text(rec.get("输入文本", ""))
    if emo:
        return emo
    return "neutral"

def load_ref_pool(ref_jsonl: Path) -> tuple[dict[str, list[dict]], list[dict]]:
    """读取参考 jsonl，按基础情感分桶。返回 (pool_by_emotion, all_entries)。"""
    pool: dict[str, list[dict]] = defaultdict(list)
    all_entries: list[dict] = []
    with ref_jsonl.open(encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            rec = json.loads(line)
            ap = "/home/ma-user/work/dataset/csh_bj/BB03/" + rec.get("audio_path")
            tx = rec.get("text", "")
            if not ap:
                continue
            entry = {"audio_path": ap, "text": tx}
            all_entries.append(entry)
            emo = base_emotion_from_text(tx)
            if emo:
                pool[emo].append(entry)
    return pool, all_entries

def pick_ref(
    emotion: str,
    pool: dict[str, list[dict]],
    all_entries: list[dict],
    rng: random.Random,
) -> tuple[dict, str]:
    """按情感随机取一条参考；缺失时回退 neutral，再回退全库。返回 (entry, 实际来源)。"""
    if emotion.replace("1", "").replace("3", "") in EMO_MAP:
        emo_ = EMO_MAP[emotion.replace("1", "").replace("3", "")]
    else:
        emo_ = emotion
    if pool.get(emo_):
        return rng.choice(pool[emo_]), emotion
    if pool.get("neutral"):
        return rng.choice(pool["neutral"]), "neutral(fallback)"
    return rng.choice(all_entries), "any(fallback)"

def load_tasks(input_jsonl: Path, skip_dims: set[str], start: int, end: int) -> list[dict]:
    tasks: list[dict] = []
    with input_jsonl.open(encoding="utf-8") as f:
        for line in f.readlines()[start:end]:
            line = line.strip()
            if not line:
                continue
            print(line)
            rec = json.loads(line)
            if rec.get("评测维度") in skip_dims:
                continue
            tasks.append(rec)
    return tasks

