def parse_emotion_tags(text: str) -> list[tuple[str, str | None]]:
    """提取可识别的标签，返回规范化的 (基础情绪, 强度) 列表。"""
    tags: list[tuple[str, str | None]] = []
    for raw_emotion, intensity in EMO_TAG_RE.findall(text or ""):
        emotion = EMOTION_ALIASES.get(raw_emotion.strip().lower())
        if emotion:
            tags.append((emotion, intensity or None))
    return tags


def target_emotion_for_entry(rec: dict) -> tuple[str, str | None]:
    """返回目标的 (情绪, 强度)；没有情绪标签的条目默认 neutral、无强度。"""
    tags = parse_emotion_tags(rec.get("输入文本", ""))
    return tags[0] if tags else ("neutral", None)


def load_ref_pool(ref_jsonl: Path) -> dict[str, dict[str | None, list[dict]]]:
    """只读取纯单一情绪参考，并按基础情绪和强度分桶。

    纯单一情绪：一条 BB03 文本中恰好存在一个【...】标签，且该标签是可识别的
    目标情绪。任何含有多个情绪或其它情绪标签的文本都会被排除。
    """
    pool: dict[str, dict[str | None, list[dict]]] = defaultdict(lambda: defaultdict(list))
    with ref_jsonl.open(encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            rec = json.loads(line)
            audio_rel = rec.get("audio_path", "")
            text = rec.get("text", "")
            if not audio_rel:
                continue

            # 先数全部标签，避免把 happy + neutral 或 happy + interest 当成纯 happy。
            if len(EMO_TAG_RE.findall(text)) != 1:
                continue
            tags = parse_emotion_tags(text)
            if len(tags) != 1:
                continue

            emotion, intensity = tags[0]
            pool[emotion][intensity].append({
                "audio_path": "/home/ma-user/work/dataset/csh_bj/BB03/" + audio_rel,
                "text": text,
                "emotion": emotion,
                "intensity": intensity,
            })
    return pool


def pick_ref(
    emotion: str,
    intensity: str | None,
    pool: dict[str, dict[str | None, list[dict]]],
    rng: random.Random,
) -> tuple[dict, str]:
    """严格选择纯情绪参考。

    有强度的目标（如 happy3）只能从同一强度中选择；无强度目标（如 happy）
    才从该纯情绪的所有强度中随机选择。没有匹配时直接报错，绝不跨情绪或跨强度。
    """
    by_intensity = pool.get(emotion, {})
    if intensity is None:
        candidates = [entry for entries in by_intensity.values() for entry in entries]
        source = f"{emotion}(pure, any intensity)"
    else:
        candidates = by_intensity.get(intensity, [])
        source = f"{emotion}{intensity}(pure, exact intensity)"

    if not candidates:
        raise RuntimeError(
            f"没有可用的纯参考：emotion={emotion!r}, intensity={intensity!r}。"
            "为避免混合情绪或错误强度，已停止推理。"
        )
    return rng.choice(candidates), source


def load_tasks(input_jsonl: Path, skip_dims: set[str], start: int, end: int) -> list[dict]:
    tasks: list[dict] = []
    with input_jsonl.open(encoding="utf-8") as f:
        for line in f.readlines()[start:end]:
            line = line.strip()
            if not line:
                continue
            print(line)
            rec = json.loads(line)
            if rec.get("评测维度") in skip_dims:
                continue
            tasks.append(rec)
    return tasks

def main() -> None:
    ap = argparse.ArgumentParser()
    ap.add_argument("--model", default="/home/ma-user/work/dataset/csh_bj/lite/Qwen3-TTS/script/ckpt/pretrain_v14/checkpoint-step-3800", help="可控 TTS 模型/权重路径")
    ap.add_argument("--ref_jsonl", default="/home/ma-user/work/dataset/csh_bj/BB03/BB03_51h_cleaned.jsonl", help="参考音频 jsonl（每条 {audio_path,text}，情感在 text 的【tag】里）")
    ap.add_argument("--input", default=str(HERE / "control_eval_v1.jsonl"))
    ap.add_argument("--out_dir", default=str(HERE / "infer_out_v1"))
    ap.add_argument("--ready_dir", default="", help="已有合格 WAV 目录；默认 <out_dir>/wavs_ready")
    ap.add_argument("--device", default="cuda:0")
    ap.add_argument("--language", default="Auto")
    ap.add_argument("--batch_size", type=int, default=8)
    ap.add_argument("--start", type=int, default=0, help="只跑前 N 条（0=全部）")
    ap.add_argument("--end", type=int, default=0, help="只跑前 N 条（0=全部）")
    ap.add_argument("--seed", type=int, default=0)
    ap.add_argument("--x_vector_only", default=True, help="只用音色 embedding，不做 ICL（默认关闭=ICL）")
    ap.add_argument("--skip_dims", default="语速", help="跳过的评测维度，逗号分隔（默认跳过语速）")
    args = ap.parse_args()

    rng = random.Random(args.seed)
    skip_dims = {d.strip() for d in args.skip_dims.split(",") if d.strip()}

    input_jsonl = Path(args.input)
    ref_jsonl = Path(args.ref_jsonl)
    out_dir = Path(args.out_dir)
    wav_dir = out_dir / "wavs"
    ready_dir = Path(args.ready_dir) if args.ready_dir else out_dir / "wavs_ready"
    wav_dir.mkdir(parents=True, exist_ok=True)

    tasks = load_tasks(input_jsonl, skip_dims, args.start, args.end)
    pool = load_ref_pool(ref_jsonl)
    if not pool:
        raise RuntimeError(f"参考 jsonl 为空或没有纯单一情绪条目: {ref_jsonl}")

    print(f"待合成条目: {len(tasks)}（已跳过维度: {sorted(skip_dims)}）")
    summary_parts = []
    for emotion, by_intensity in sorted(pool.items()):
        levels = ", ".join(
            f"{level or 'none'}:{len(entries)}"
            for level, entries in sorted(by_intensity.items(), key=lambda item: item[0] or "")
        )
        summary_parts.append(f"{emotion}({levels})")
    print(f"纯单一情绪参考池: {{ {', '.join(summary_parts)} }}")
    # 为每条任务预先选好参考，便于批处理与记录
    for t in tasks:
        emotion, intensity = target_emotion_for_entry(t)
        t["_target_emotion"] = emotion
        t["_target_intensity"] = intensity

        if t.get("ref_audio"):
            # 人工指定的参考音频优先，避免被随机选择覆盖。
            t["_ref_audio"] = t["ref_audio"]
            t["_ref_text"] = t.get("ref_text", "")
            t["_ref_src"] = "manual(ref_audio)"
            continue

        ref, src = pick_ref(emotion, intensity, pool, rng)
        print(ref, t)
        t["_ref_audio"] = ref["audio_path"]
        t["_ref_text"] = ref["text"]
        t["_ref_src"] = src

    # 加载模型
    print(f"加载模型: {args.model}")
    tts = Qwen3TTSModel.from_pretrained(
        args.model,
        device_map=args.device,
        dtype=torch.bfloat16,
        attn_implementation="flash_attention_2",
    )

    manifest_path = out_dir / "manifest.jsonl"
    n_ok, n_err = 0, 0
    t_start = time.time()
    with manifest_path.open("w", encoding="utf-8") as mf:
        for i in range(0, len(tasks), args.batch_size):
            batch = tasks[i:i + args.batch_size]
            texts = [b["输入文本"] for b in batch]
            langs = [args.language] * len(batch)
            ref_audios = [b["_ref_audio"] for b in batch]
            xvo = [args.x_vector_only] * len(batch)
            # try:
            #     wavs, sr = tts.generate_voice_clone(
            #         text=texts,
            #         language=langs,
            #         ref_audio=ref_audios,
            #         x_vector_only_mode=xvo,
            #         **COMMON_GEN_KWARGS,
            #     )
            # except Exception as exc:  # noqa: BLE001
                # print(f"[batch {i}-{i+len(batch)-1}] 批处理失败，逐条重试: {exc}", file=sys.stderr)
            batch = [b for b in batch if not (ready_dir / f"{b['ID']}.wav").exists()]
            wavs, sr = _fallback_per_item(tts, batch, args)

            for b, w in zip(batch, wavs):
                if w is None:
                    n_err += 1
                    continue
                wav_name = f"{b['ID']}.wav"
                sf.write(str(wav_dir / wav_name), w, sr)
                rec = {
                    "ID": b["ID"],
                    "wav_path": str(wav_dir / wav_name),
                    "评测维度": b["评测维度"],
                    "控制值": b.get("控制值", ""),
                    "强度": b.get("强度", ""),
                    "期望标记": b.get("期望标记", ""),
                    "输入文本": b["输入文本"],
                    "target_emotion": b["_target_emotion"],
                    "target_intensity": b["_target_intensity"],
                    "ref_audio": b["_ref_audio"],
                    "ref_text": b["_ref_text"],
                    "ref_src": b["_ref_src"],
                }
                mf.write(json.dumps(rec, ensure_ascii=False) + "\n")
                mf.flush()
                n_ok += 1
            print(f"  进度 {min(i+len(batch), len(tasks))}/{len(tasks)}  ok={n_ok} err={n_err}")

    dt = time.time() - t_start
    print(f"\n完成：ok={n_ok} err={n_err}，用时 {dt:.1f}s")
    print(f"音频目录: {wav_dir}")
    print(f"清单: {manifest_path}")

def _fallback_per_item(tts, batch: list[dict], args) -> tuple[list, int]:
    """批处理失败时逐条合成，失败的条目对应 None。"""
    wavs: list = []
    sr = 24000
    for b in batch:
        try:
            w, sr = tts.generate_voice_clone(
                text=b["输入文本"],
                language=args.language,
                ref_audio=b["_ref_audio"],
                ref_text=b["_ref_text"],
                x_vector_only_mode=args.x_vector_only,
                non_streaming_mode=True,
                # **COMMON_GEN_KWARGS,
            )
            wavs.append(w[0])
        except Exception as exc:  # noqa: BLE001
            print(f"    [{b['ID']}] 单条失败: {exc}", file=sys.stderr)
            wavs.append(None)
    return wavs, sr

if __name__ == "__main__":
    main()

