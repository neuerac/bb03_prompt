            #         **COMMON_GEN_KWARGS,
            #     )
            # except Exception as exc:  # noqa: BLE001
                # print(f"[batch {i}-{i+len(batch)-1}] 批处理失败，逐条重试: {exc}", file=sys.stderr)
            batch = [b for b in batch if not os.path.exists(f"/home/ma-user/work/dataset/csh_bj/jiangziyue/Qwen3-TTS/script/infer_out_v1/wavs_ready/{b['ID']}.wav")]
            wavs, sr = _fallback_per_item(tts, batch, args)

            for b, w in zip(batch, wavs):
